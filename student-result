        // Define answer keys for each module
        const answerKeys = {
          'UNIC_TEST_01': {
                'q1': 'B', 'q2': 'A', 'q3': 'B', 'q4': 'A', 'q5': 'B',
                'q6': 'A', 'q7': 'B', 'q8': 'B', 'q9': 'B', 'q10': 'B',
    'q11': 'B', 'q12': 'A', 'q13': 'B', 'q14': 'B', 'q15': 'A'
            }
        };

        // Define marking schemes for each module
        const markingSchemes = {
            'UNIC_TEST_01': {
                correct: 1,
                wrong: -0.33,
                noAnswer: 0
            }
        };

          function isCorrect(userAnswer, correctAnswer) {

            if (!userAnswer || correctAnswer == null) return false;

            if (Array.isArray(correctAnswer)) {
                correctAnswer = correctAnswer.join(';');
            }

            userAnswer = String(userAnswer).trim();
            correctAnswer = String(correctAnswer).trim();

            const lower = correctAnswer.toLowerCase();

            if (lower.includes('to')) {
                const [min, max] = correctAnswer.split('to').map(x => Number(x.trim()));
                const userValue = Number(userAnswer);
                return userValue >= min && userValue <= max;
            }

            if (correctAnswer.includes('OR')) {
                const options = correctAnswer.split('OR').map(a => a.trim());
                return options.includes(userAnswer);
            }

            if (correctAnswer.includes(';')) {
                const correct = correctAnswer.split(';').map(a => a.trim()).sort();
                const user = userAnswer.split(';').map(a => a.trim()).sort();
                return correct.length === user.length &&
                    correct.every((v,i)=>v===user[i]);
            }

            return userAnswer === correctAnswer;
        }

        async function fetchStudentResponses() {
            const examModule = document.getElementById('examModule').value;
            const searchType = document.getElementById('searchType').value;
            const searchValue = document.getElementById('searchValue').value;

            const query = `
                query GetUniqdata($searchValue: String!, $examModule: String!) {
                    uniqdata(where: {${searchType}: {_eq: $searchValue}, exam_module: {_eq: $examModule}} order_by: {timedate: desc}
                limit: 1) {
                        email
                        exam_module
                        name
                        s_id
                        id
                        correct
                        marks
                        responses
                        timedate
                    }
                }
            `;

            const variables = {
                searchValue: searchValue,
                examModule: examModule
            };

            try {
                const response = await fetch(process.env.HASURA_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-hasura-admin-secret': process.env.HASURA_SECRET // Replace with your actual Hasura admin secret
                    },
                    body: JSON.stringify({
                        query: query,
                        variables: variables
                    })
                });
                const result = await response.json();
                console.log(result);
                displayResponses(result.data.uniqdata, examModule);
            } catch (error) {
                console.error('Error fetching responses:', error);
                document.getElementById('responseContent').innerHTML = '<p class="text-danger">There was an error fetching the responses. Please try again.</p>';
            }
        }

        function displayResponses(responses, examModule) {
            const responseContent = document.getElementById('responseContent');
            if (responses.length === 0) {
                responseContent.innerHTML = '<p class="text-warning">No responses found.</p>';
                return;
            }
            

            // Find the latest timestamp response
            responses.sort((a, b) => new Date(b.timedate) - new Date(a.timedate));
            const latestResponse = responses[0];

            // Get the correct answer key and marking scheme for the selected exam module
            const answerKey = answerKeys[examModule];
            const markingScheme = markingSchemes[examModule];

            let totalQuestions = Object.keys(answerKey).length;
            let score = 0;

            const responsesObject = JSON.parse(latestResponse.responses);

            let totalAttempted = 0;
            let totalCorrect = 0;
            let positiveMarks = 0;
            let negativeMarks = 0;
            let totalnotattemp = 0;
            let totalwrong = 0;

            // Calculate the marks
            Object.keys(responsesObject).forEach(question => {

                const userAnswer = responsesObject[question];
                const correctAnswer = answerKey[question];

                if (userAnswer === '' || userAnswer === 'Not Answered' || userAnswer === 'N') {

                    score += markingScheme.noAnswer;
                    totalnotattemp++;

                } 
                else if (isCorrect(userAnswer, correctAnswer)) {

                    score += markingScheme.correct;
                    totalCorrect++;
                    positiveMarks += markingScheme.correct;

                } 
                else {

                    score += markingScheme.wrong;
                    totalwrong++;
                    negativeMarks += markingScheme.wrong;

                }

            });
            totalAttempted = totalCorrect+totalwrong;

            // Display student info
            let html = `
                
            <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white">
            Student Details
            </div>

            <div class="card-body">

            <div class="row">

