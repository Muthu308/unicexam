            <th>Attempted</th>
            <th>Correct</th>
            <th>Not Answered</th>
            <th>Wrong</th>
            <th>Positive</th>
            <th>Negative</th>
            <th>Final</th>
            </tr>
            </thead>

            <tbody>
            <tr>

            <td><span class="badge bg-info">${totalAttempted}</span></td>

            <td><span class="badge bg-success">${totalCorrect}</span></td>

            <td><span class="badge bg-secondary">${totalnotattemp}</span></td>

            <td><span class="badge bg-danger">${totalwrong}</span></td>

            <td class="text-success fw-bold">${positiveMarks}</td>

            <td class="fw-bold ${negativeMarks < 0 ? 'text-danger' : 'text-dark'}">
            ${negativeMarks}
            </td>

            <td class="fw-bold text-primary fs-5">
            <b>${Number(score.toFixed(2))}</b>
            </td>

            </tr>
            </tbody>

            </table>

            </div>
            </div> `;


            // Create the HTML table
            html += `
                <div class="card shadow-sm">

                <div class="card-header bg-info text-white">
                Latest Student Response 
                <span class="badge bg-warning text-dark">
                ${latestResponse.timedate}
                </span>
                </div>

                <div class="card-body table-responsive">

                <table class="table table-hover table-bordered align-middle">

                <thead class="table-light">
                <tr>
                <th>Question</th>
                <th>Your Response</th>
                <th>Correct Answer</th>
                <th>Marks</th>
                </tr>
                </thead>

                <tbody>`;

            // Add rows for each question and answer
            Object.keys(responsesObject).forEach(question => {
                    let marks = 0;
                    const userAnswer = responsesObject[question];
                    const correctAnswer = answerKey[question];

                    if (userAnswer === '' || userAnswer === 'Not Answered' || userAnswer === 'N') {

                        marks = markingScheme.noAnswer;

                    } 
                    else if (isCorrect(userAnswer, correctAnswer)) {

                        marks = markingScheme.correct;

                    } 
                    else {

                        marks = markingScheme.wrong;

                    }

                html += `
                    <tr>
                        <td>${question.toUpperCase()}</td>
                        <td>${responsesObject[question]}</td>
                        <td>${answerKey[question]}</td>
                        <td style="color: ${marks < 0 ? 'red' : 'black'}">${marks}</td>
                    </tr>`;
            });

            html += `
                    </tbody>
                </table><br><button class="btn btn-success" onclick="printToPDF()">Print to PDF</button>`;

            responseContent.innerHTML = html;
        }
