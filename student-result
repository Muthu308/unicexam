            <strong>Email:</strong> ${latestResponse.email}
            </div>

            <div class="col-md-6 mb-2">
            <strong>Exam Module:</strong> ${latestResponse.exam_module}
            </div>

            <div class="col-md-6 mb-2">
            <strong>Name:</strong> ${latestResponse.name}
            </div>

            <div class="col-md-6 mb-2">
            <strong>Student ID:</strong> ${latestResponse.s_id}
            </div>

            <div class="col-md-12 mt-2">
            <strong>Total Marks:
            <span class="badge bg-primary text-white fs-6">
            ${Number(score.toFixed(2))} / ${totalQuestions * markingScheme.correct}
            </span></strong> 
            </div>

            </div>

            </div>
            </div>`;

            html += `
            <div class="card shadow-sm mb-3">

            <div class="card-header bg-success text-white">
            Summary of Results
            </div>

            <div class="card-body table-responsive">

            <table class="table table-bordered text-center align-middle">

