              "latex": true,
              "question": "If $A = \\begin{pmatrix} 1 & 2 \\\\ 3 & 4 \\end{pmatrix}$, then $\\det(A) = $",
              "options": ["2", "-2", "10", "-10"],
              "answer": [1],
              "explanation": "$\\det(A) = 1\\cdot4 - 2\\cdot3 = 4-6 = -2$."
            },
