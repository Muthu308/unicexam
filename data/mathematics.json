              "id": "ma_q1",
              "type": "MCQ",
              "latex": true,
              "question": "Evaluate: $\\lim_{x \\to 0} \\frac{\\sin x}{x}$",
              "options": ["0", "1", "$\\infty$", "Does not exist"],
              "answer": [1],
              "explanation": "This is a standard limit: $\\lim_{x \\to 0} \\frac{\\sin x}{x} = 1$."
            },
            {
              "id": "ma_q2",
              "type": "MSQ",
              "latex": true,
              "question": "Which of the following limits equal 1? (Select all that apply)",
              "options": [
                "$\\lim_{x\\to 0}\\frac{\\tan x}{x}$",
                "$\\lim_{x\\to 0}\\frac{e^x - 1}{x}$",
                "$\\lim_{x\\to\\infty}\\frac{1}{x}$",
                "$\\lim_{x\\to 0}\\frac{\\ln(1+x)}{x}$"
              ],
              "answer": [0, 1, 3],
              "explanation": "All three equal 1 by standard limit results. $\\lim_{x\\to\\infty}\\frac{1}{x} = 0$."
            }
          ]
        },
