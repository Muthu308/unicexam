              "id": "ma_q5",
              "type": "MSQ",
              "latex": true,
              "question": "Which of the following are properties of a symmetric matrix $A$? (Select all that apply)",
              "options": [
                "$A = A^T$",
                "$A = -A^T$",
                "Eigenvalues are real",
                "Determinant is always positive"
              ],
              "answer": [0, 2],
              "explanation": "A symmetric matrix satisfies $A=A^T$ and always has real eigenvalues (spectral theorem). Determinant can be negative."
            }
          ]
