              "type": "MCQ",
              "latex": true,
              "question": "If $f(x) = x^3 - 3x^2 + 2$, then $f'(x) = 0$ at:",
              "options": ["$x = 0, 2$", "$x = 1, 2$", "$x = -1, 2$", "$x = 0, 3$"],
              "answer": [0],
              "explanation": "$f'(x) = 3x^2 - 6x = 3x(x-2) = 0 \\Rightarrow x = 0$ or $x = 2$."
            }
          ]
        }
