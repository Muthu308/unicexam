          "title": "Ch 1: Laws of Motion",
          "questions": [
            {
              "id": "ph_q1",
              "type": "MCQ",
              "latex": true,
              "question": "A body of mass $m$ is placed on a frictionless incline of angle $\\theta$. The acceleration of the body along the incline is:",
              "options": [
                "$g \\sin\\theta$",
                "$g \\cos\\theta$",
                "$g \\tan\\theta$",
                "$g$"
              ],
              "answer": [0],
              "explanation": "On a frictionless incline, the component of gravity along the surface is $mg\\sin\\theta$, so $a = g\\sin\\theta$."
            },
            {
              "id": "ph_q2",
              "type": "MSQ",
              "latex": true,
              "question": "Which of the following are correct statements about Newton's Third Law? (Select all that apply)",
              "options": [
                "Action and reaction forces act on different bodies",
                "Action and reaction forces are equal in magnitude",
                "Action and reaction forces cancel each other",
                "Action and reaction are opposite in direction"
              ],
              "answer": [0, 1, 3],
              "explanation": "Newton's Third Law: action-reaction pairs act on different bodies, are equal in magnitude and opposite in direction. They do NOT cancel because they act on different bodies."
            },
            {
              "id": "ph_q3",
              "type": "MCQ",
              "latex": true,
              "question": "A force $\\vec{F} = 10\\hat{i} + 5\\hat{j}$ N acts on a 2 kg body. The magnitude of acceleration is:",
              "options": [
                "$5\\sqrt{5}$ m/s²",
                "$\\frac{5\\sqrt{5}}{2}$ m/s²",
                "$10$ m/s²",
                "$\\frac{15}{2}$ m/s²"
              ],
              "answer": [1],
              "explanation": "$|\\vec{F}| = \\sqrt{10^2+5^2} = 5\\sqrt{5}$ N. $a = F/m = 5\\sqrt{5}/2$ m/s²."
            }
          ]
        },
        {
          "id": "ph_u1_c2",
          "title": "Ch 2: Work, Energy & Power",
          "questions": [
            {
              "id": "ph_q4",
              "type": "MCQ",
              "latex": true,
              "question": "The work done by a force $\\vec{F}$ over displacement $\\vec{d}$ is given by:",
              "options": [
                "$|\\vec{F}||\\vec{d}|$",
                "$\\vec{F} \\times \\vec{d}$",
                "$\\vec{F} \\cdot \\vec{d}$",
                "$\\frac{|\\vec{F}|}{|\\vec{d}|}$"
              ],
              "answer": [2],
              "explanation": "Work is the dot product: $W = \\vec{F} \\cdot \\vec{d} = |F||d|\\cos\\theta$."
            },
            {
              "id": "ph_q5",
              "type": "MSQ",
              "latex": true,
              "question": "Which of the following are conservative forces? (Select all that apply)",
              "options": [
                "Gravitational force",
                "Friction force",
                "Spring (elastic) force",
                "Air drag"
              ],
              "answer": [0, 2],
              "explanation": "Conservative forces (gravity, spring) have work independent of path. Friction and drag are non-conservative."
            }
          ]
        }
      ]
    },
